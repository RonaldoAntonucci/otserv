# Install as /etc/otserv/otserv.env, owned by root, and replace placeholders.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=forgottenserver
MYSQL_USER=otserv
MYSQL_PASSWORD=CHANGE_ME_VPS_PASSWORD
MYSQL_SOCK=

TFS_IP=CHANGE_ME_PUBLIC_IP_OR_DOMAIN
TFS_LOGIN_PORT=7171
TFS_GAME_PORT=7172
TFS_STATUS_PORT=7171
TFS_MAP_NAME=forgotten
TFS_PROTOCOL=13.10
